# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth
# ADMIN_PASSWORD: server-only; compared via timing-safe equal in lib/auth.ts.
# Do NOT expose as NEXT_PUBLIC_ADMIN_PASSWORD — that bundles it into client JS.
ADMIN_PASSWORD=

# ADMIN_SESSION_SECRET: HMAC key for signing the admin_session cookie.
# Required (>=16 chars). Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
